{
  "keyboard.dispatch": "code",
  "editor.lineNumbers": "relative",
  "notebook.lineNumbers": "on",
  "vim.enable": true,
  "vim.sneak": true,
  "vim.useSystemClipboard": true,
  "vim.surround": true,
  "vim.leader": " ",
  "workbench.colorTheme": "Gruvbox Dark Hard",

  "vim.insertModeKeyBindings": [
    {
      "before": ["j", "k"],
      "after": ["<Esc>"]
    },
    {
      "before": ["<C-h>"],
      "after": ["<Left>"]
    },
    {
      "before": ["<C-l>"],
      "after": ["<Right>"]
    },
    {
      "before": ["<C-j>"],
      "after": ["<Down>"]
    },
    {
      "before": ["<C-k>"],
      "after": ["<Up>"]
    }
  ],

  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": ["H"],
      "after": ["^"]
    },
    {
      "before": ["L"],
      "after": ["$"]
    },
    {
      "before": ["<Tab>"],
      "commands": ["editor.action.indentLines"]
    },
    {
      "before": ["<S-Tab>"],
      "commands": ["editor.action.outdentLines"]
    },
    {
      "before": ["d"],
      "after": ["\"", "_", "d"]
    },
    {
      "before": ["d", "d"],
      "after": ["\"", "_", "d", "d"]
    },
    {
      "before": ["<CR>"],
      "after": ["a", "<CR>", "<Esc>"]
    },
    {
      "before": ["e", "e"],
      "after": ["$"]
    },
    {
      "before": ["<C-/>"],
      "commands": ["editor.action.commentLine"]
    },
    {
      "before": ["<leader>", "t", "t"],
      "commands": ["workbench.action.selectTheme"]
    },
    {
      "before": ["<leader>", "q"],
      "commands": ["workbench.action.closeActiveEditor"]
    },
    {
      "before": ["<leader>", "r"],
      "commands": ["python.execInTerminal"],
      "when": "editorLangId == python"
    }
  ],

  "vim.visualModeKeyBindings": [
    {
      "before": ["j", "k"],
      "after": ["<Esc>"]
    }
    // {
    //   "before": ["i"],
    //   "after": ["<Esc>", "i"]
    // }
  ],

  "vim.visualModeKeyBindingsNonRecursive": [
    {
      "before": ["H"],
      "after": ["^"]
    },
    {
      "before": ["L"],
      "after": ["$"]
    },
    {
      "before": ["J"],
      "commands": ["editor.action.moveLinesDownAction"],
      "after": ["g", "v"]
    },
    {
      "before": ["K"],
      "commands": ["editor.action.moveLinesUpAction"],
      "after": ["g", "v"]
    },
    {
      "before": ["<Tab>"],
      "commands": ["editor.action.indentLines"],
      "after": ["g", "v"]
    },
    {
      "before": ["<S-Tab>"],
      "commands": ["editor.action.outdentLines"],
      "after": ["g", "v"]
    },
    {
      "before": ["d"],
      "after": ["\"", "_", "d"]
    },
    {
      "before": ["e", "e"],
      "after": ["$"]
    },
    {
      "before": ["<C-/>"],
      "commands": ["editor.action.commentLine"]
    }
  ],
  "github.copilot.chat.languageContext.fix.typescript.enabled": true,
  "github.copilot.chat.languageContext.inline.typescript.enabled": true,
  "chat.editing.explainChanges.enabled": true,
  "chat.tips.enabled": false,
  "editor.inlineSuggest.edits.allowCodeShifting": "never",
  "editor.inlineSuggest.edits.renderSideBySide": "never",
  "editor.inlineSuggest.enabled": false,
  "editor.inlineSuggest.suppressSuggestions": true,
  "editor.suggest.snippetsPreventQuickSuggestions": true,
  "terminal.integrated.suggest.suggestOnTriggerCharacters": true,
  "terminal.integrated.tabs.showIcons": true,
  "terminal.integrated.profiles.linux": {
    "Ubuntu": {
      "path": "/usr/bin/bash",
      "icon": "terminal-ubuntu"
    },
    "Python": {
      "path": "/usr/bin/python3",
      "args": ["-i"],
      "icon": "python"
    }
  },
  "terminal.integrated.defaultProfile.linux": "Ubuntu",
  "terminal.integrated.fontFamily": "FiraCode Nerd Font Mono",
  "workbench.iconTheme": "fira-code-material-minimal",
  "editor.fontFamily": "fira-code-nerd, FiraCode Nerd Font, Consolas, 'Courier New', monospace",
  "editor.fontLigatures": true
}

